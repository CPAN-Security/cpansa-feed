#!/usr/bin/env perl
use 5.36.0;
use warnings;

use FindBin qw($Bin);
use Getopt::Long qw(GetOptions);
use lib "$Bin/../lib";

use CPANSec::Feed::CPANSA qw(load_database);
use CPANSec::Feed::Generator qw(write_feed_json);

my %opt = (
  cpansa_json => $ENV{CPANSEC_FEED_CPANSA_JSON} // "var/cpan-security-advisory.json",
  cvelist_dir => $ENV{CPANSEC_FEED_CVELIST_DIR} // "cvelistV5",
  schema_path => $ENV{CPANSEC_FEED_SCHEMA_PATH} // "schema.json",
  metacpan_cache_dir => $ENV{CPANSEC_FEED_METACPAN_CACHE_DIR} // "var/metacpan-cache",
  metacpan_cache_ttl => $ENV{CPANSEC_FEED_METACPAN_CACHE_TTL} // 6 * 60 * 60,
);

GetOptions(
  "cpansa-json=s" => \$opt{cpansa_json},
  "cvelist-dir=s" => \$opt{cvelist_dir},
  "schema-path=s" => \$opt{schema_path},
  "report-html=s" => \$opt{report_html},
  "output=s" => \$opt{output},
  "metacpan-cache-dir=s" => \$opt{metacpan_cache_dir},
  "metacpan-cache-ttl=i" => \$opt{metacpan_cache_ttl},
) or die "invalid options\n";

die "--output is required\n" if !$opt{output};

my $db = load_database($opt{cpansa_json});
my $json = write_feed_json(
  cpansa_db => $db,
  cve_dir => $opt{cvelist_dir},
  schema_path => $opt{schema_path},
  report_html => $opt{report_html},
  output => $opt{output},
  metacpan_cache_dir => $opt{metacpan_cache_dir},
  metacpan_cache_ttl => $opt{metacpan_cache_ttl},
);

binmode(STDOUT, ":encoding(UTF-8)");
print $json;
