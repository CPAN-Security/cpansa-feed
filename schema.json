{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hackeriet.github.io/cpansa-feed/v1/schema.json",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[A-Za-z0-9_-]+$": {
      "description": "distribution name to an array of report data",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["affected_versions", "distribution", "version_range", "affected_releases"],
        "properties": {
          "cpansa_id": {
            "type": "string"
          },
          "affected_versions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "cves": {
            "type": "array",
            "items": {
              "description": "CVE id",
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "reported": {
            "type": "string",
            "format": "date"
          },
          "severity": {
            "enum": ["minor", "medium", "moderate", "high", "critical"]
          },
          "distribution": {
            "type": "string"
          },
          "version_range": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "affected_releases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cve_id": {
            "type": "string"
          },
          "cve": {
            "type": "object"
          },
          "title": {
            "type": "string"
          }
        }
      }
    }
  }
}
